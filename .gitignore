# 忽略 node_modules 目录
node_modules/
package-lock.json

# 忽略打包输出目录
dist/
build/

# 忽略日志文件
*.log

# 忽略本地配置文件
.env
.env.*
# 但保留生产构建变量(VPS 构建需读取它启用 config 外置)
!.env.production

# 忽略 Claude Code 本地状态(worktree / launch.json 等)
.claude/

# 忽略 VPS 本地真实 API 地址(不入库,部署时由 deploy.sh 注入)
deploy/api.env

# 忽略 macOS 和 Windows 系统文件
.DS_Store
Thumbs.db

# 忽略 VSCode 工作区配置（可选）
.vscode/

# 忽略 IDE 临时文件（如 WebStorm/JetBrains 系）
.idea/
