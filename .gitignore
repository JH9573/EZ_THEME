# 忽略 node_modules 目录
node_modules/
package-lock.json

# 忽略打包输出目录
dist/
build/

# 忽略日志文件
*.log

# 忽略本地配置文件
.env
.env.*
# 但保留生产构建变量(VPS 构建需读取它启用 config 外置)
!.env.production

# 忽略 Claude Code 本地状态(worktree / launch.json 等)
.claude/

# 真实配置不入库:仓库只存模板 src/config/index.example.js
# 实际配置(后端地址、密钥、站点名等)放在本地 src/config/index.js,永不提交
src/config/index.js

# 忽略 macOS 和 Windows 系统文件
.DS_Store
Thumbs.db

# 忽略 VSCode 工作区配置（可选）
.vscode/

# 忽略 IDE 临时文件（如 WebStorm/JetBrains 系）
.idea/
