# 生产环境构建变量(仅构建时使用,不影响运行时)

# config.js 外置开关:
#   true  = 抽成 dist 下独立明文 JS 文件,可直接在服务器改配置免重新构建(需处理 CDN 缓存)
#   false = 配置打包进 JS,改配置需重新构建
VUE_APP_CONFIGJS=true

# 页面加载前(JS 执行前)浏览器标签显示的标题,构建时写入 index.html
# 之后 JS 会按配置里的 siteName 覆盖成最终标题,这里只是首屏占位,改成你的品牌即可
VUE_APP_TITLE=UUCNet

# 环境标识(可选)
VUE_APP_ENV=production
